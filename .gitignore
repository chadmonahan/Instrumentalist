# Xcode / build
# NOTE: the .xcodeproj is generated by XcodeGen (project.yml) but is committed
# too, so the repo can be cloned and opened without running xcodegen. Re-run
# `xcodegen generate` after changing project.yml or adding/removing files. Only
# the shared project files are tracked; per-user state below stays ignored.
build/
DerivedData/
*.xcuserstate
xcuserdata/

# Local machine config
Local.xcconfig

# macOS
.DS_Store
